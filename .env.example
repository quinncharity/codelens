# Web
VITE_ANALYZER_BASE_URL=http://localhost:8080/rpc

# Analyzer
CODELENS_HOST=0.0.0.0
CODELENS_PORT=8080
CODELENS_DB_PATH=.data/codelens.sqlite
CODELENS_REPO_CACHE_DIR=.data/repos
CODELENS_MAX_CONCURRENT_JOBS=1

# Production durable storage (recommended on Vercel serverless)
# When BLOB_READ_WRITE_TOKEN is present, the serverless RPC handler will store
# analysis records durably in Vercel Blob instead of ephemeral /tmp SQLite.
# BLOB_READ_WRITE_TOKEN=
# CODELENS_STORAGE_BACKEND=vercel_blob
# CODELENS_BLOB_PREFIX=codelens/v1

# LLM engine (provider keys depend on the LM you choose)
#
# Groq example:
CODELENS_DSPY_LM=groq/openai/gpt-oss-120b
GROQ_API_KEY=
#
# OpenRouter example:
# CODELENS_DSPY_LM=openrouter/x-ai/grok-code-fast-1
# OPENROUTER_API_KEY=
# OR_SITE_URL=http://localhost
# OR_APP_NAME=CodeLens
#
# Optional configuration
# CODELENS_DSPY_TEMPERATURE=0.0
# CODELENS_RLM_SNAPSHOT_MAX_BYTES=2000000
