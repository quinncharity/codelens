# Web
VITE_ANALYZER_BASE_URL=http://localhost:8080/rpc

# Analyzer
CODELENS_HOST=0.0.0.0
CODELENS_PORT=8080
CODELENS_DB_PATH=.data/codelens.sqlite
CODELENS_REPO_CACHE_DIR=.data/repos
CODELENS_MAX_CONCURRENT_JOBS=1

# RLM engine (requires DSPy + Deno; provider keys depend on the LM you choose)
#
# OpenRouter example:
CODELENS_DSPY_LM=openrouter/x-ai/grok-code-fast-1
OPENROUTER_API_KEY=
# OR_SITE_URL=http://localhost
# OR_APP_NAME=CodeLens
#
# Optional: cheaper sub-LM for RLM sub-queries
# CODELENS_DSPY_SUB_LM=openrouter/google/gemini-2.0-flash-001
# CODELENS_DSPY_TEMPERATURE=0.0
# CODELENS_RLM_SNAPSHOT_MAX_BYTES=2000000
# CODELENS_RLM_MAX_ITERATIONS=8
# CODELENS_RLM_MAX_LLM_CALLS=25
# CODELENS_RLM_MAX_OUTPUT_CHARS=100000
# CODELENS_RLM_VERBOSE=0
