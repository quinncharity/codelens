{
  "name": "@codelens/analyzer",
  "private": true,
  "scripts": {
    "presync": "test -d .venv || uv sync --dev",
    "predev": "pkill -9 -f '^.*/\\.venv/bin/uvicorn.*analyzer' 2>/dev/null || true",
    "dev": ".venv/bin/uvicorn analyzer.server:app --app-dir src --reload --reload-dir src/analyzer --host ${CODELENS_HOST:-0.0.0.0} --port ${CODELENS_PORT:-8080}",
    "build": "node -e \"console.log('analyzer: nothing to build')\"",
    "lint": "uv sync --dev && uv run ruff check src",
    "test": "uv sync --dev && uv run pytest -q"
  }
}
